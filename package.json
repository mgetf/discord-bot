{
  "name": "discord-bot-template",
  "version": "1.0.0",
  "description": "Type-safe Discord bot template with Bun and Biome",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow bun",
    "start": "bun run ./src/index.ts",
    "deploy-commands": "bun run ./src/deploy.ts",
    "fmt": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "discord.js": "^14.25.1",
    "pino": "^10.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "bun-types": "^1.3.5",
    "lefthook": "^2.0.13",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  }
}
