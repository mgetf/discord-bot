# Discord Bot credentials
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here

# Optional: Deploy commands to a specific guild for faster updates (development)
DISCORD_GUILD_ID=your_guild_id_here

# mge.tf API
MGE_API_URL=https://mge.tf
MGE_API_KEY=mge_your_api_key_here

# Discord role to assign on successful verification
VERIFIED_ROLE_ID=your_verified_role_id_here

# Optional: Restrict /verify to a specific channel
VERIFICATION_CHANNEL_ID=

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
